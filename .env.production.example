# Frontend production env. Copy to .env.production and fill in.
#   cp .env.production.example .env.production
#
# ⚠️ Vite bakes these into the JS bundle AT BUILD TIME — set them BEFORE `npm run build`
# (or before `docker build`). These are public values (shipped to the browser); the real
# secrets live in the backend, never here.

# Backend base URL used when NOT on localhost.
# Using the provided Dockerfile (java -jar, embedded Tomcat) the backend serves at ROOT,
# so DO NOT add /membershipms. Only add a context path if you deploy the .war to an
# external Tomcat under that path.
VITE_CONTEXT_URL=https://your-backend-domain
VITE_CONTEXT_URL_LOCAL=http://localhost:8080

VITE_STORAGE_TOKEN=ACTION_IN_THAI_MEMBERSHIP_TOKEN
VITE_STORAGE_USER=ACTION_IN_THAI_MEMBERSHIP_USER
VITE_STORAGE_MENU=ACTION_IN_THAI_MEMBERSHIP_MENU
VITE_STORAGE_UPLOAD_TIME=10000
VITE_STORAGE_DOWNLOAD_TIME=15000
VITE_STORAGE_CHECK_IN=scanIn
VITE_STORAGE_CHECK_OUT=scanOut

# Production OAuth IDs (must have the production domain configured in each provider console)
VITE_AUTH_GOOGLE_ID="<GOOGLE_CLIENT_ID>"
VITE_AUTH_FACEBOOK_ID="<FACEBOOK_APP_ID>"
VITE_AUTH_LINE_LIFF="<LINE_LIFF_ID>"
